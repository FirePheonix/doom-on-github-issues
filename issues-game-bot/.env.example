# Server
PORT=3000

# GitHub app target and auth
GITHUB_TOKEN=ghp_your_github_token_here
GITHUB_OWNER=FirePheonix
GITHUB_REPO=tetris-on-pdf
GITHUB_WEBHOOK_SECRET=replace_with_random_webhook_secret

# Public URL for frame links in issue bodies.
# Prefer PUBLIC_BASE_URL. RAILWAY_PUBLIC_DOMAIN is an alternative on Railway.
PUBLIC_BASE_URL=https://your-service.example.com
# RAILWAY_PUBLIC_DOMAIN=your-app.up.railway.app

# Frame storage
# Default behavior:
# - if FRAME_S3_BUCKET is set, frame store defaults to s3
# - otherwise frame store defaults to local
FRAME_STORE=s3
FRAME_S3_BUCKET=your-public-frame-bucket
FRAME_S3_REGION=us-east-1
FRAME_S3_PREFIX=frames
FRAME_S3_PUBLIC_BASE_URL=https://your-public-frame-bucket.s3.us-east-1.amazonaws.com
# FRAME_S3_ENDPOINT=https://s3.us-east-1.amazonaws.com
# FRAME_S3_FORCE_PATH_STYLE=false

# Session persistence
# Default behavior:
# - if DATABASE_URL is set, repository mode defaults to postgres
# - otherwise repository mode defaults to file
SESSION_REPOSITORY=postgres
SESSION_REPOSITORY_SCHEMA=public
SESSION_REPOSITORY_TABLE=issue_sessions

# Session event journal persistence
# Default behavior follows SESSION_REPOSITORY / DATABASE_URL unless overridden.
SESSION_EVENT_REPOSITORY=postgres
SESSION_EVENT_REPOSITORY_SCHEMA=public
SESSION_EVENT_REPOSITORY_TABLE=issue_session_events

# Postgres connection string
DATABASE_URL=postgres://user:password@host:5432/database

# Webhook / lifecycle tuning
ISSUE_COOLDOWN_MS=1200
DOOM_BOOT_DELAY_MS=500
DOOM_INACTIVITY_MS=300000

# Python runtime
PYTHON_BIN=python3

# Doom engine selection
DOOM_ENGINE=doomgeneric
DOOM_MODE=demons
DOOM_TICS_PER_COMMENT=4
DOOM_SESSION_WORKER_TIMEOUT_MS=20000

# Frame output tuning
DOOM_FRAME_SCALE=0.8
DOOM_PNG_COMPRESS_LEVEL=3
DOOM_PNG_OPTIMIZE=false
