# Copy this file to `.env` and fill the values you actually use.
# Production path:
# - Postgres for session state/event journal
# - S3-compatible object storage for frame publishing
# Local fallback path:
# - SESSION_REPOSITORY=file
# - SESSION_EVENT_REPOSITORY=file
# - FRAME_STORE=local
# - leave DATABASE_URL / FRAME_S3_* / AWS_* unset

# Server
PORT=3000

# GitHub target and auth (required)
GITHUB_TOKEN=ghp_replace_me
GITHUB_OWNER=your-github-org-or-user
GITHUB_REPO=your-github-repo
GITHUB_WEBHOOK_SECRET=replace_with_long_random_secret

# Public app URL used when issue bodies need an absolute frame URL.
# Prefer PUBLIC_BASE_URL. RAILWAY_PUBLIC_DOMAIN is a fallback for Railway deploys.
PUBLIC_BASE_URL=https://your-service.example.com
# RAILWAY_PUBLIC_DOMAIN=your-app.up.railway.app

# Session persistence mode
# Default:
# - postgres when DATABASE_URL is set
# - file otherwise
SESSION_REPOSITORY=postgres
SESSION_REPOSITORY_SCHEMA=public
SESSION_REPOSITORY_TABLE=issue_sessions

# Session event journal mode
# Default follows the session repository mode unless explicitly overridden.
SESSION_EVENT_REPOSITORY=postgres
SESSION_EVENT_REPOSITORY_SCHEMA=public
SESSION_EVENT_REPOSITORY_TABLE=issue_session_events

# Command journal mode
# Default follows DATABASE_URL unless explicitly overridden.
SESSION_COMMAND_REPOSITORY=postgres
SESSION_COMMAND_REPOSITORY_SCHEMA=public
SESSION_COMMAND_REPOSITORY_TABLE=issue_session_commands

# Runtime lease mode
# Default follows DATABASE_URL unless explicitly overridden.
SESSION_LEASE_REPOSITORY=postgres
SESSION_LEASE_REPOSITORY_SCHEMA=public
SESSION_LEASE_REPOSITORY_TABLE=issue_session_leases

# Frame metadata mode
# Default follows DATABASE_URL unless explicitly overridden.
SESSION_FRAME_REPOSITORY=postgres
SESSION_FRAME_REPOSITORY_SCHEMA=public
SESSION_FRAME_REPOSITORY_TABLE=issue_session_frames

# Postgres
DATABASE_URL=postgres://username:password@hostname:5432/database_name

# Frame storage mode
# Default:
# - s3 when FRAME_S3_BUCKET is set
# - local otherwise
FRAME_STORE=s3
FRAME_S3_BUCKET=your-public-frame-bucket
FRAME_S3_REGION=us-east-1
FRAME_S3_PREFIX=frames
FRAME_S3_PUBLIC_BASE_URL=https://your-public-frame-bucket.s3.us-east-1.amazonaws.com

# S3-compatible auth / endpoint
# These are typically required outside AWS-hosted environments.
AWS_ACCESS_KEY_ID=replace_me
AWS_SECRET_ACCESS_KEY=replace_me
# AWS_SESSION_TOKEN=
# AWS_REGION=us-east-1
# FRAME_S3_ENDPOINT=https://s3.us-east-1.amazonaws.com
# FRAME_S3_FORCE_PATH_STYLE=false

# Webhook / lifecycle tuning
ISSUE_COOLDOWN_MS=1200
DOOM_BOOT_DELAY_MS=500
DOOM_INACTIVITY_MS=300000

# Python runtime
PYTHON_BIN=python3

# Doom runtime
DOOM_ENGINE=doomgeneric
DOOM_MODE=demons
DOOM_TICS_PER_COMMENT=4
DOOM_SESSION_WORKER_TIMEOUT_MS=20000

# Frame output tuning
DOOM_FRAME_SCALE=0.8
DOOM_PNG_COMPRESS_LEVEL=3
DOOM_PNG_OPTIMIZE=false
